{
    "name": "treztreiz/twig-components",
    "version": "1.3.0",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "TwigComponents\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TwigComponents\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs:fix": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "lint": "phpstan analyse",
        "check": [
            "@cs:check",
            "@lint",
            "@test"
        ]
    }
}
